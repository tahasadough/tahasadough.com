{
	"name": "tahasadough.com",
	"private": true,
	"version": "0.9.3",
	"type": "module",
	"packageManager": "pnpm@9.15.9",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "pnpm test:unit --run",
		"validate": "pnpm check && pnpm test && pnpm build"
	},
	"lint-staged": {
		"*.{svelte,js,ts}": [
			"eslint --fix",
			"prettier --write"
		]
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/enhanced-img": "^0.9.3",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24.12.4",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.18.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.5",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.55.10",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^7.3.3",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"class-variance-authority": "^0.7.1"
	}
}
